# ── Google OAuth ──────────────────────────────────────────────
# Google Cloud Console에서 받은 OAuth 클라이언트(데스크톱 앱) JSON 경로
SRIRACHA_CREDENTIALS=credentials.json
# 발급된 토큰 저장 경로 (python -m sriracha.auth 실행 시 생성)
SRIRACHA_TOKEN=token.json

# ── Gmail ─────────────────────────────────────────────────────
# 미처리 메일 검색 쿼리. 영수증 판별은 LLM이 하지만, 키워드로 1차로 좁히면
# 불필요한 LLM 호출이 줄어 효율적이다. 받은편지함 전체를 보려면 'in:inbox' 로.
# 특정 메일링 그룹만 보려면 'list:your-group@example.com' 추가.
SRIRACHA_GMAIL_QUERY=(영수증 OR 결제 OR receipt OR invoice OR payment OR 카드) -label:sriracha/done -in:chats
# 처리 완료 표시용 라벨 (없으면 자동 생성)
SRIRACHA_DONE_LABEL=sriracha/done
# 한 번 실행에서 처리할 최대 메일 수
SRIRACHA_MAX_MESSAGES=20

# ── 스프레드시트 ──────────────────────────────────────────────
SRIRACHA_SPREADSHEET_ID=
# 데이터가 들어갈 탭 이름. '{year}' 를 넣으면 영수증 연도별 탭으로 자동 라우팅된다.
# 예: '{year}년 사용내역' → 2026 영수증은 '2026년 사용내역' 탭으로. 없으면 자동 생성.
SRIRACHA_SHEET_TAB=Sheet1
# 탭 자동생성 시 1행에 들어갈 제목 (헤더 위에 여유가 있을 때)
SRIRACHA_SHEET_TITLE=사용내역
# 첫 데이터 행 (1-based). 제목1행 + 헤더1행이면 3, 헤더만 있으면 2.
SRIRACHA_FIRST_DATA_ROW=2
# 컬럼 순서 (A열부터 매핑). 가능한 키: date, vendor, currency, amount, amount_krw, receipt_no
SRIRACHA_COLUMNS=date,vendor,currency,amount,amount_krw,receipt_no
# 원화(amount_krw) 컬럼은 시트 수식 '=금액*$환율셀' 로 기록한다.
# 이 셀(예: J1)에 기준환율을 적어두면, 값만 바꿔도 모든 외화 행의 원화가 자동 갱신된다.
SRIRACHA_RATE_CELL=J1
# 탭 자동생성 시 환율셀 초기값
SRIRACHA_DEFAULT_RATE=1500

# ── vLLM (OpenAI 호환) ────────────────────────────────────────
SRIRACHA_VLLM_BASE_URL=http://localhost:8000/v1
SRIRACHA_VLLM_API_KEY=EMPTY
# 비워두면 /v1/models 에서 자동 선택. 특정 모델을 강제하려면 id 지정.
SRIRACHA_MODEL=
# 한 실행 내 가벼운 재시도 횟수 (실패해도 다음 cron 때 재시도됨)
SRIRACHA_LLM_RETRIES=2
# 한 LLM 요청 타임아웃(초). 병렬로 보내면 vLLM 큐에 쌓일 수 있어 넉넉히.
SRIRACHA_REQUEST_TIMEOUT=600
# 동시 LLM 요청 수. vLLM 의 max-num-seqs 와 맞추면 좋다.
SRIRACHA_CONCURRENCY=4

# ── 로컬 상태 ─────────────────────────────────────────────────
# 처리 기록 JSON 파일 (백업: 그냥 파일 복사).
SRIRACHA_DB=sriracha_store.json
# 이미지 longest-edge 리사이즈 한계(px)
SRIRACHA_IMAGE_MAX_EDGE=1600
# PDF 렌더 DPI
SRIRACHA_PDF_DPI=170
